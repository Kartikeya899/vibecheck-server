PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/vibecheck

# JWT secrets - use long random strings in production
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Anthropic API key for the AI recommendation engine
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173
